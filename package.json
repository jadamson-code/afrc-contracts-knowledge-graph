{
  "name": "afrc-contracts-knowledge-graph",
  "version": "0.1.0",
  "description": "Interactive knowledge graph visualization of Air Force Reserve Component AFRC contracts using Sigma.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "fetch-data": "tsx scripts/fetch-contracts.ts",
    "transform-data": "tsx scripts/transform-to-graph.ts"
  },
  "dependencies": {
    "@react-sigma/core": "^5.0.1",
    "@sigma/edge-curve": "^3.1.0",
    "graphology": "^0.25.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "axios": "^1.6.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lodash": "^4.17.21",
    "d3-scale": "^4.0.2",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/lodash": "^4.17.14",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-checker": "^0.8.0",
    "tsx": "^4.7.0"
  }
}
