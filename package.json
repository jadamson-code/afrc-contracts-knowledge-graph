{
  "name": "@sigma/root",
  "description": "A JavaScript library aimed at visualizing graphs of thousands of nodes and edges.",
  "homepage": "https://www.sigmajs.org",
  "bugs": "http://github.com/jacomyal/sigma.js/issues",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm exec --workspaces -- npx rimraf node_modules && npx rimraf node_modules",
    "build": "preconstruct build && npm run build-bundle --workspace=sigma",
    "prettify": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run && npm run test:type --workspace=@sigma/test && npm run test:e2e --workspace=@sigma/test",
    "test:unit": "vitest run",
    "test:type": "npm run test:type --workspace=@sigma/test",
    "test:e2e": "npm run test:e2e --workspace=@sigma/test",
    "start": "preconstruct dev && npm run start --workspace=@sigma/website",
    "createPackage": "ts-node bin/create-package.ts",
    "postinstall": "preconstruct dev",
    "postpublish": "preconstruct dev",
    "website:build": "npm run build --workspace=@sigma/website",
    "prepublishOnly": "npm run test && npm run build && npm run lint"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@preconstruct/cli": "^2.8.10",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "lerna": "^8.1.9",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8",
    "@vitest/browser": "^2.1.8",
    "playwright": "^1.49.1"
  },
  "preconstruct": {
    "packages": [
      "packages/sigma",
      "packages/node-border",
      "packages/node-image",
      "packages/node-piechart",
      "packages/layer-leaflet",
      "packages/layer-maplibre",
      "packages/layer-webgl",
      "packages/export-image",
      "packages/utils"
    ],
    "exports": {
      "importConditionDefaultExport": "default"
    }
  }
}
