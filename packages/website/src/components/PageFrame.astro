---
import MobileMenuToggle from "virtual:starlight/components/MobileMenuToggle";

const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="v4-notice" id="v4-notice">
  <span>This is the <strong>alpha v4 version</strong> website.</span>
  <a href="https://sigmajs.org">Looking for the v3 documentation?</a>
</div>
<script>
  function updateNoticeHeight() {
    const notice = document.getElementById("v4-notice");
    if (notice) {
      document.documentElement.style.setProperty("--sl-v4-notice-height", notice.offsetHeight + "px");
    }
  }
  updateNoticeHeight();
  window.addEventListener("resize", updateNoticeHeight);
</script>
<div class="page sl-flex">
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar print:hidden" aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}>
        <MobileMenuToggle />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
</div>

<style>
  /* ------------------------------------------------------------------
   * v4-notice banner
   * All positioning adjustments caused by the notice live here,
   * co-located with the component that introduces it.
   * ------------------------------------------------------------------ */

  :global(:root) {
    --sl-v4-notice-height: 2em;
  }

  .v4-notice {
    background: var(--cream);
    color: black;
    text-align: center;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 11;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }

  .v4-notice a {
    color: var(--ruby);
    white-space: nowrap;
  }

  /* ------------------------------------------------------------------
   * Page layout
   * ------------------------------------------------------------------ */

  .page {
    flex-direction: column;
    min-height: 100vh;
  }

  .header {
    z-index: var(--sl-z-index-navbar);
    position: fixed;
    inset-inline-start: 0;
    inset-block-start: var(--sl-v4-notice-height);
    width: 100%;
    height: var(--sl-nav-height);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
    padding-inline-end: var(--sl-nav-pad-x);
    background-color: var(--sl-color-bg-nav);
  }

  :global([data-has-sidebar]) .header {
    padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
  }

  .sidebar-pane {
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block: calc(var(--sl-nav-height) + var(--sl-v4-notice-height)) 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-black);
    overflow-y: auto;
  }

  :global([aria-expanded="true"]) ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .sidebar-content {
    height: 100%;
    min-height: max-content;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: "";
      padding-bottom: 1px;
    }
  }

  .main-frame {
    padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height) + var(--sl-v4-notice-height));
    padding-inline-start: var(--sl-content-inline-start);
  }

  @media (min-width: 50rem) {
    :global([data-has-sidebar]) .header {
      padding-inline-end: var(--sl-nav-pad-x);
    }
    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      width: var(--sl-sidebar-width);
      background-color: var(--sl-color-bg-sidebar);
      border-inline-end: 1px solid var(--sl-color-hairline-shade);
    }
  }

  /* ------------------------------------------------------------------
   * Starlight mobile component overrides
   * These components use --sl-nav-height as their top anchor without
   * knowing about our notice banner, so we shift them down here.
   * ------------------------------------------------------------------ */

  /* Burger button: vertically centered within the navbar, below the notice */
  :global(starlight-menu-button button) {
    top: calc(var(--sl-v4-notice-height) + (var(--sl-nav-height) - var(--sl-menu-button-size)) / 2);
  }

  /* Mobile TOC bar: sits just below the navbar */
  :global(mobile-starlight-toc nav) {
    top: calc(var(--sl-v4-notice-height) + var(--sl-nav-height) - 1px);
  }

  /* Mobile TOC dropdown: reduce max-height to avoid overflow off-screen */
  :global(mobile-starlight-toc .dropdown) {
    max-height: calc(85vh - var(--sl-v4-notice-height) - var(--sl-nav-height) - var(--sl-mobile-toc-height));
  }
</style>
