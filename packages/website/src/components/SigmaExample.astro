---
/**
 * Embeds a sigma.js example in a Starlight docs page via an iframe.
 *
 * Usage in MDX:
 *   import SigmaExample from '../../components/SigmaExample.astro';
 *   <SigmaExample id="events" />
 *
 * The `id` must match a file at src/examples/{id}.astro.
 * The example is rendered in an iframe pointing to /embed/{id}/.
 */

interface Props {
  id: string;
  height?: string;
}

const { id, height = "500px" } = Astro.props;
---

<div class="sigma-example">
  <iframe src={`/embed/${id}/`} style={`height: ${height}`} title={`sigma.js example: ${id}`} loading="lazy"></iframe>
  <div class="sigma-example-toolbar">
    <a
      href={`https://github.com/jacomyal/sigma.js/blob/v4/packages/website/src/examples/${id}.astro`}
      target="_blank"
      rel="noopener">View source on GitHub</a
    >
    <span class="sigma-example-toolbar-sep"></span>
    <a href={`/embed/${id}/`} target="_blank" rel="noopener">Open in new tab</a>
  </div>
</div>

<style>
  .sigma-example {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5, #e0e0e0);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .sigma-example iframe {
    display: block;
    width: 100%;
    border: none;
  }
  .sigma-example-toolbar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0 !important;
    padding: 0.4rem 0.75rem;
    border-top: 1px solid var(--sl-color-gray-5, #e0e0e0);
    background: var(--sl-color-gray-7, #f5f5f5);
    font-size: 0.8rem;
  }
  .sigma-example-toolbar-sep {
    width: 1px;
    height: 0.9em;
    background: var(--sl-color-gray-5, #ccc);
  }
  .sigma-example-toolbar a {
    color: var(--sl-color-text-accent, #0369a1);
    text-decoration: none;
  }
  .sigma-example-toolbar a:hover {
    text-decoration: underline;
  }
</style>
