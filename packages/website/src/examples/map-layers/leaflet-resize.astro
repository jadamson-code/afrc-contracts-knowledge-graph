<div id="sigma-container"></div>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
  #sigma-container {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import bindLeafletLayer from "@sigma/layer-leaflet";
  import Graph from "graphology";
  import type { Attributes, SerializedGraph } from "graphology-types";
  import Sigma from "sigma";
  import { DEFAULT_STYLES } from "sigma/types";

  import { registerControls } from "../_controls";

  const container = document.getElementById("sigma-container") as HTMLElement;

  const res = await fetch("/data/airports.json");
  const data = await res.json();
  const graph = Graph.from(data as SerializedGraph);
  graph.updateEachNodeAttributes((_node, attributes) => ({
    ...attributes,
    label: attributes.fullName,
    x: 0,
    y: 0,
  }));

  const renderer = new Sigma(graph, container, {
    settings: {
      labelRenderedSizeThreshold: 20,
      minEdgeThickness: 1,
    },
    styles: {
      nodes: [DEFAULT_STYLES.nodes, { color: "#e22352" }],
      edges: [DEFAULT_STYLES.edges, { color: "#ffaeaf" }],
    },
    nodeReducer: (node, data) => ({
      ...data,
      size: Math.sqrt(graph.degree(node)) / 2,
    }),
  });

  bindLeafletLayer(renderer, {
    getNodeLatLng: (attrs: Attributes) => ({ lat: attrs.latitude, lng: attrs.longitude }),
  });

  let isSmall = false;
  registerControls({
    toggle: {
      type: "button",
      label: "Toggle size",
      action: () => {
        isSmall = !isSmall;
        container.style.width = isSmall ? "50%" : "100%";
        container.style.height = isSmall ? "50%" : "100%";
        renderer.refresh({ schedule: false });
      },
    },
  });
</script>
